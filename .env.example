# Firebase (config do projeto no Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Verificação de propriedade (Search Console) - só o valor do content da meta tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# AdSense (opcional; se nao definido, usa ca-pub-5278426429130746)
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-5278426429130746

# Assistente conversacional (RAG + LLM). So funciona com deploy que tenha API (nao static export).
# Defina NEXT_PUBLIC_CHAT_ENABLED=true apenas se /api/chat estiver disponivel no deploy.
OPENAI_API_KEY=
NEXT_PUBLIC_CHAT_ENABLED=

# Vector DB (opcional; se não definido, usa store in-memory)
# PINECONE_API_KEY=
# PINECONE_INDEX=
# PINECONE_HOST=https://<index>.svc.<region>.pinecone.io

# Lead capture: webhook URL (POST JSON com name, email, phone, message, source)
LEAD_WEBHOOK_URL=
